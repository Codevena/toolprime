---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { FaviconGenerator } from '@/components/tools/FaviconGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('favicon-generator')
if (!tool) throw new Error('Tool not found: favicon-generator')
---

<ToolLayout tool={tool}>
  <FaviconGenerator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Favicon Generator</h2>
    <ol class="step-list" role="list">
      <li>Click the upload area or drag and drop your image</li>
      <li>Preview favicons in all standard sizes (16x16 to 512x512)</li>
      <li>Review the generated HTML link tags</li>
      <li>Click <strong>Download ZIP</strong> to get all sizes plus the HTML code</li>
    </ol>
  </section>
</ToolLayout>
