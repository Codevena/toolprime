---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { InvoiceGenerator } from '@/components/tools/InvoiceGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('invoice-generator')
if (!tool) throw new Error('Tool not found: invoice-generator')
---

<ToolLayout tool={tool}>
  <InvoiceGenerator client:load />

  <section slot="content" class="mt-8 prose prose-slate max-w-none dark:prose-invert">
    <h2>How to Use the Invoice Generator</h2>
    <p>
      Fill in your company details, client information, and invoice details. Add line items with descriptions, quantities, and unit prices. The tool automatically calculates subtotals, tax, and the grand total. Click <strong>Download PDF Invoice</strong> to generate and save the invoice.
    </p>
    <p>
      Choose your currency (USD, EUR, GBP, CHF, JPY) and set a tax rate if applicable. Add notes for payment terms or additional information.
    </p>

    <h2>Privacy</h2>
    <p>
      The PDF is generated entirely in your browser. Your invoice data, company details, and client information are never sent to any server or stored anywhere.
    </p>
  </section>
</ToolLayout>
