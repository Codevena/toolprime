---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { InvoiceGenerator } from '@/components/tools/InvoiceGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('invoice-generator')
if (!tool) throw new Error('Tool not found: invoice-generator')
---

<ToolLayout tool={tool}>
  <InvoiceGenerator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Invoice Generator</h2>
    <ol class="step-list" role="list">
      <li>Fill in your company name, address, and logo</li>
      <li>Add client details and invoice number</li>
      <li>Add line items with descriptions, quantities, and prices</li>
      <li>Set tax rate and currency</li>
      <li>Click <strong>Download PDF</strong> to save your invoice</li>
    </ol>
  </section>
</ToolLayout>
