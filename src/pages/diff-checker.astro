---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { DiffChecker } from '@/components/tools/DiffChecker'
import { getToolById } from '@/data/tools'

const tool = getToolById('diff-checker')
if (!tool) throw new Error('Tool not found: diff-checker')
---

<ToolLayout tool={tool}>
  <DiffChecker client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Diff Checker</h2>
    <ol class="step-list" role="list">
      <li>Paste the original text in the left panel</li>
      <li>Paste the modified text in the right panel</li>
      <li>View additions highlighted in green and deletions in red</li>
      <li>Toggle between line-level and word-level diff modes</li>
      <li>Copy the diff output with one click</li>
    </ol>
  </section>
</ToolLayout>
