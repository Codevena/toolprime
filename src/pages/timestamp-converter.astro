---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { TimestampConverter } from '@/components/tools/TimestampConverter'
import { getToolById } from '@/data/tools'

const tool = getToolById('timestamp-converter')
if (!tool) throw new Error('Tool not found: timestamp-converter')
---

<ToolLayout tool={tool}>
  <TimestampConverter client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Timestamp Converter</h2>
    <ol class="step-list" role="list">
      <li>View the current Unix timestamp updating in real time</li>
      <li>Enter a Unix timestamp to convert to a human-readable date</li>
      <li>Or enter a date to convert to a Unix timestamp</li>
      <li>Toggle between seconds and milliseconds</li>
      <li>Copy any value with one click</li>
    </ol>
  </section>
</ToolLayout>
