---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { GradientIcon } from '@/components/ui/GradientIcon'
import SchemaMarkup from '@/components/seo/SchemaMarkup.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import { getToolById } from '@/data/tools'
import { audienceHubs } from '@/data/audienceHubs'
import { getHubMeta } from '@/lib/seo'
import { breadcrumbSchema } from '@/lib/schema'

const hub = audienceHubs.find((h) => h.audience === 'everyday')!
const meta = getHubMeta(hub.title, hub.description, '/everyday')
---

<BaseLayout {...meta}>
  <SchemaMarkup json={breadcrumbSchema([
    { name: 'Home', url: 'https://toolprime.dev/' },
    { name: 'Everyday Tools', url: 'https://toolprime.dev/everyday' },
  ])} />

  <Breadcrumbs items={[{ name: 'Everyday Tools', url: 'https://toolprime.dev/everyday' }]} />

  {/* Hero */}
  <section class="text-center pt-8 pb-12">
    <h1 class="text-4xl sm:text-5xl font-extrabold mb-3 tracking-tight" style="letter-spacing: -0.03em;">
      <span class="bg-clip-text text-transparent" style={`background-image: ${hub.gradient};`}>
        {hub.heading}
      </span>
    </h1>
    <p class="text-[var(--color-text-muted)] text-base mb-8 max-w-lg mx-auto">
      {hub.subheading}
    </p>
  </section>

  <section class="mb-12">
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div class="lg:col-span-2">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">Start With the Problem You Need to Solve</h2>
          <p class="text-sm leading-relaxed text-[var(--color-text-muted)] mb-4">
            Everyday tools work best when they save a decision, not just a calculation. This hub groups the fastest utilities for budgeting, percentages, date math, unit conversion, and simple business tasks so you can get an answer quickly without installing anything or creating an account.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <a href="/currency-converter" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Money and Travel</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Compare currencies, budgets, and amounts when you are planning payments or travel costs.</p>
            </a>
            <a href="/percentage-calculator" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Quick Math</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Solve percentages, fractions, BMI, and date calculations without digging through spreadsheets.</p>
            </a>
            <a href="/invoice-generator" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Simple Business Tasks</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Generate invoices, QR codes, and other practical assets for small daily workflows.</p>
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-5">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Most Useful First</h2>
          <div class="space-y-3">
            <a href="/currency-converter" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">Currency Converter</div>
              <div class="text-sm text-[var(--color-text-muted)]">Strong everyday utility for travel, pricing, and comparison.</div>
            </a>
            <a href="/percentage-calculator" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">Percentage Calculator</div>
              <div class="text-sm text-[var(--color-text-muted)]">Fastest path for discounts, increases, and ratio questions.</div>
            </a>
            <a href="/date-calculator" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">Date Calculator</div>
              <div class="text-sm text-[var(--color-text-muted)]">Helpful for deadlines, planning, and everyday time math.</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-bold text-[var(--color-text)] mb-4">Common Everyday Workflows</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">Budget and Price Checks</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Compare costs, calculate discounts, and check payment amounts quickly.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/currency-converter" class="text-[var(--color-primary)] underline hover:no-underline">Currency Converter</a> → <a href="/percentage-calculator" class="text-[var(--color-primary)] underline hover:no-underline">Percentage Calculator</a> → <a href="/invoice-generator" class="text-[var(--color-primary)] underline hover:no-underline">Invoice Generator</a></p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">Planning and Scheduling</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Figure out age, durations, due dates, and time differences without manual counting.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/date-calculator" class="text-[var(--color-primary)] underline hover:no-underline">Date Calculator</a> → <a href="/age-calculator" class="text-[var(--color-primary)] underline hover:no-underline">Age Calculator</a> → <a href="/timezone-converter" class="text-[var(--color-primary)] underline hover:no-underline">Timezone Converter</a></p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">Sharing and Utility Tasks</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Create QR codes, count words, or convert units when you just need a fast answer.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/qr-code-generator" class="text-[var(--color-primary)] underline hover:no-underline">QR Code Generator</a> → <a href="/word-counter" class="text-[var(--color-primary)] underline hover:no-underline">Word Counter</a> → <a href="/unit-converter" class="text-[var(--color-primary)] underline hover:no-underline">Unit Converter</a></p>
      </div>
    </div>
  </section>

  {/* Subcategory Sections */}
  {hub.subcategories.map((sub) => {
    const subTools = sub.toolIds.map((id) => getToolById(id)).filter((t) => t !== undefined)
    if (subTools.length === 0) return null
    return (
      <section class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xs font-semibold uppercase tracking-wider whitespace-nowrap text-[var(--color-text-muted)]">
            {sub.name}
          </h2>
          <div class="flex-1 h-px bg-[var(--color-border)]" style="opacity:0.4;" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {subTools.map((tool) => (
            <a
              href={tool.path}
              class="group flex items-start gap-3 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] hover:shadow-lg hover:-translate-y-px transition-all"
            >
              <GradientIcon icon={tool.icon} category={tool.category} size={36} />
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-[var(--color-text)] mb-0.5">{tool.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] line-clamp-2">{tool.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  })}

  {/* Browse Other Categories */}
  <section class="border-t border-[var(--color-border-subtle)] pt-8 mt-8">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Browse Other Categories</h2>
    <div class="flex flex-wrap gap-3">
      <a href="/developer" class="px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)] transition-all">
        Developer Tools
      </a>
      <a href="/design" class="px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)] transition-all">
        Design Tools
      </a>
    </div>
  </section>
</BaseLayout>
