---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { ColorPicker } from '@/components/tools/ColorPicker'
import { getToolById } from '@/data/tools'

const tool = getToolById('color-picker')
if (!tool) throw new Error('Tool not found: color-picker')
---

<ToolLayout tool={tool}>
  <ColorPicker client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Color Picker</h2>
    <ol class="step-list" role="list">
      <li>Click the color preview area or use the picker to select a color</li>
      <li>View instant conversions in HEX, RGB, and HSL formats</li>
      <li>Click any value to copy it to your clipboard</li>
      <li>Adjust individual R, G, B or H, S, L sliders for fine control</li>
    </ol>
  </section>
</ToolLayout>
