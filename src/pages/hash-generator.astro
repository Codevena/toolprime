---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { HashGenerator } from '@/components/tools/HashGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('hash-generator')
if (!tool) throw new Error('Tool not found: hash-generator')
---

<ToolLayout tool={tool}>
  <HashGenerator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Hash Generator</h2>
    <ol class="step-list" role="list">
      <li>Enter or paste your text into the input field</li>
      <li>View MD5, SHA-1, SHA-256, and SHA-512 hashes generated instantly</li>
      <li>Click any hash value to copy it to your clipboard</li>
      <li>Compare hashes to verify data integrity</li>
    </ol>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="related-content">
    <h2 id="related-content" class="text-xl font-bold text-[var(--color-text)] mb-3">Popular Hash Lookups</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-2">
      {['hello', 'password', 'admin', 'test', '123456', 'world', 'example', 'user'].map((word) => (
        <a href={`/hashes/md5-${word}`}
          class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center">
          <span class="text-sm font-medium">MD5 of "{word}"</span>
        </a>
      ))}
    </div>
  </section>
</ToolLayout>
