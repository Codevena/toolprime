---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import { bmiPresets, getCategoryColor } from '@/data/bmiData'
import { getBmiIndexMeta } from '@/lib/seo'

const meta = getBmiIndexMeta()

const heights = [150, 155, 160, 165, 170, 175, 180, 185, 190, 195, 200]
---

<BaseLayout {...meta}>
  <Breadcrumbs items={[
    { name: 'BMI Calculator', url: 'https://toolprime.dev/bmi-calculator' },
    { name: 'Pre-Calculated BMI', url: meta.canonical },
  ]} />

  <h1 class="text-3xl font-bold mb-2">Pre-Calculated BMI Tables</h1>
  <p class="text-[var(--color-text-muted)] mb-6">
    Browse BMI results for 200+ height and weight combinations. Each page shows your BMI category, healthy weight range, and WHO classification.
  </p>

  {heights.map((height) => {
    const entries = bmiPresets.filter((p) => p.heightCm === height)
    return entries.length > 0 ? (
      <section class="mb-8">
        <h2 class="text-lg font-semibold mb-3">BMI for {height} cm</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-2">
          {entries.map((e) => (
            <a href={`/calculators/bmi/${e.slug}`}
              class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center">
              <span class="text-sm font-medium">{e.weightKg} kg</span>
              <span class="block text-xs font-bold" style={`color: ${getCategoryColor(e.category)}`}>
                {e.bmi} — {e.category}
              </span>
            </a>
          ))}
        </div>
      </section>
    ) : null
  })}
</BaseLayout>
