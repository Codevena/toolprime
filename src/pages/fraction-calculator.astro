---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { FractionCalculator } from '@/components/tools/FractionCalculator'
import { getToolById } from '@/data/tools'

const tool = getToolById('fraction-calculator')
if (!tool) throw new Error('Tool not found: fraction-calculator')
---

<ToolLayout tool={tool}>
  <FractionCalculator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Fraction Calculator</h2>
    <ol class="step-list" role="list">
      <li>Enter the <strong>first fraction</strong> (numerator and denominator)</li>
      <li>Select an <strong>operation</strong>: add, subtract, multiply, or divide</li>
      <li>Enter the <strong>second fraction</strong></li>
      <li>View the <strong>simplified result</strong> with decimal and percentage equivalents</li>
      <li>Follow the <strong>step-by-step solution</strong> to understand the math</li>
    </ol>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="popular-fractions">
    <h2 id="popular-fractions" class="text-xl font-bold text-[var(--color-text)] mb-3">Popular Fraction Calculations</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
      <a href="/calculate/1-2-plus-1-3" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">1/2 + 1/3</a>
      <a href="/calculate/1-2-plus-1-4" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">1/2 + 1/4</a>
      <a href="/calculate/1-3-plus-1-4" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">1/3 + 1/4</a>
      <a href="/calculate/2-3-plus-1-4" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">2/3 + 1/4</a>
      <a href="/calculate/3-4-minus-1-2" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">3/4 − 1/2</a>
      <a href="/calculate/1-2-times-1-3" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">1/2 × 1/3</a>
      <a href="/calculate/3-4-dividedby-1-2" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">3/4 ÷ 1/2</a>
      <a href="/calculate/2-3-times-3-4" class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center text-sm">2/3 × 3/4</a>
    </div>
  </section>
</ToolLayout>
