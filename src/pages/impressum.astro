    <p><strong>Angaben gemäß § 5 TMG:</strong></p>
    <p>
      [Name]<br />
      [Straße Nr.]<br />
      [PLZ Ort]<br />
      Deutschland
    </p>
    <p><strong>Kontakt:</strong></p>
    <p>E-Mail: [email@example.com]</p>
    <p><strong>Verantwortlich für den Inhalt nach § 55 Abs. 2 RStV:</strong></p>
    <p>[Name], [Adresse]</p>
  </div>
</BaseLayout>
