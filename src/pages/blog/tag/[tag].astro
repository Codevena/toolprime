---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import { getCollection } from 'astro:content'
import { getBlogTagMeta } from '@/lib/seo'
import { howToUseArticles, conversionArticles } from '@/data/blogTemplates'

export async function getStaticPaths() {
  const posts = await getCollection('blog')

  // Collect all tags from content collection
  const tagSet = new Set<string>()
  for (const post of posts) {
    for (const tag of post.data.tags) {
      tagSet.add(tag)
    }
  }

  // Collect tags from programmatic articles
  for (const a of [...howToUseArticles, ...conversionArticles]) {
    for (const tag of a.tags) {
      tagSet.add(tag)
    }
  }

  return Array.from(tagSet).map(tag => ({
    params: { tag },
    props: { tag },
  }))
}

const { tag } = Astro.props
const meta = getBlogTagMeta(tag)

const posts = (await getCollection('blog'))
  .filter(p => p.data.tags.includes(tag))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const programmatic = [
  ...howToUseArticles.filter(a => a.tags.includes(tag)),
  ...conversionArticles.filter(a => a.tags.includes(tag)),
]

const label = tag.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())
---

<BaseLayout {...meta}>
  <Breadcrumbs items={[
    { name: 'Blog', url: 'https://toolprime.dev/blog' },
    { name: `Tag: ${label}`, url: meta.canonical },
  ]} />

  <header class="mb-8">
    <h1 class="text-3xl font-extrabold text-[var(--color-text)]" style="letter-spacing: -0.02em;">Articles tagged "{label}"</h1>
  </header>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map(post => (
      <a href={`/blog/${post.id}`} class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-5 hover:border-[var(--color-primary)] transition-colors">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block rounded-full bg-[var(--color-primary)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-primary)]">{post.data.category}</span>
          <time datetime={post.data.date.toISOString().split('T')[0]} class="text-xs text-[var(--color-text-muted)]">
            {post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
        </div>
        <h2 class="text-sm font-bold text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors mb-1">{post.data.title}</h2>
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed line-clamp-2">{post.data.description}</p>
      </a>
    ))}
    {programmatic.map(article => (
      <a href={`/blog/how-to-${article.slug}`} class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-5 hover:border-[var(--color-primary)] transition-colors">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block rounded-full bg-[var(--color-primary)]/10 px-2.5 py-0.5 text-xs font-medium text-[var(--color-primary)]">tutorial</span>
        </div>
        <h2 class="text-sm font-bold text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors mb-1">{article.title}</h2>
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed line-clamp-2">{article.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
