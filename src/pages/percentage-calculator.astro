---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { PercentageCalculator } from '@/components/tools/PercentageCalculator'
import { getToolById } from '@/data/tools'

const tool = getToolById('percentage-calculator')
if (!tool) throw new Error('Tool not found: percentage-calculator')
---

<ToolLayout tool={tool}>
  <PercentageCalculator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Percentage Calculator</h2>
    <ol class="step-list" role="list">
      <li>Choose your calculation type (X% of Y, or X is what % of Y)</li>
      <li>Enter the percentage and base values</li>
      <li>View the result with step-by-step explanation</li>
      <li>Browse pre-calculated percentages below for quick reference</li>
    </ol>

  </section>

  <section slot="content" class="mt-8" aria-labelledby="related-content">
    <h2 id="related-content" class="text-xl font-bold text-[var(--color-text)] mb-3">Pre-Calculated Percentages</h2>
    <p class="text-[var(--color-text-muted)]">
      Looking for a specific percentage? Browse our <a href="/calculators" class="text-[var(--color-primary)] underline hover:no-underline">pre-calculated percentage pages</a> for instant answers to common queries like "what is 15% of 200" or "what is 20% of 500". Over 600 combinations are available with step-by-step explanations.
    </p>
  </section>
</ToolLayout>
