---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { CurrencyConverter } from '@/components/tools/CurrencyConverter'
import { getToolById } from '@/data/tools'
import { fetchRates, getRateDate } from '@/data/currencyData'

const tool = getToolById('currency-converter')
if (!tool) throw new Error('Tool not found: currency-converter')

await fetchRates()
const rateDate = getRateDate()
---

<ToolLayout tool={tool}>
  <CurrencyConverter client:load />

  <p slot="content" class="mt-4 text-sm text-[var(--color-text-muted)]">
    Exchange rates from the <a href="https://www.ecb.europa.eu" class="underline hover:no-underline" rel="noopener">European Central Bank</a> via Frankfurter API.
    {rateDate !== 'fallback' && rateDate !== 'unknown' && <> Rates as of <strong>{rateDate}</strong>. Updated daily.</>}
  </p>

  <section slot="content" class="mt-8" aria-labelledby="currency-overview">
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
      <h2 id="currency-overview" class="text-xl font-bold text-[var(--color-text)] mb-3">When This Currency Converter Is Most Useful</h2>
      <p class="text-sm leading-relaxed text-[var(--color-text-muted)] mb-4">
        Use this converter to compare travel budgets, check international prices, estimate invoice totals, or quickly translate crypto values into major fiat currencies. It is designed for fast decision-making when you need a practical exchange estimate, not a slow financial app workflow.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Travel Planning</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Compare spending power before a trip and translate hotel, food, or transport budgets into your home currency.</p>
        </div>
        <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Business and Freelance Work</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Estimate invoice values, project budgets, or vendor costs when you work across countries and payment currencies.</p>
        </div>
        <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
          <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Crypto Reference</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Quickly translate BTC, ETH, SOL, or DOGE into major currencies when you need a simple benchmark.</p>
        </div>
      </div>
    </div>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Currency Converter</h2>
    <ol class="step-list" role="list">
      <li>Enter the <strong>amount</strong> you want to convert</li>
      <li>Select the <strong>source currency</strong> from the dropdown</li>
      <li>Select the <strong>target currency</strong> from the dropdown</li>
      <li>View the <strong>converted amount</strong> instantly with live rates</li>
      <li>Use the <strong>swap button</strong> to reverse the conversion</li>
    </ol>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="important-currency-notes">
    <h2 id="important-currency-notes" class="text-xl font-bold text-[var(--color-text)] mb-3">Important Currency Conversion Notes</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Reference Rates, Not Final Checkout Prices</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Banks, cards, exchanges, and payment providers can apply spreads, fees, or different settlement rates. Your final charged amount may differ.</p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Crypto Is More Volatile</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Crypto values can move quickly. Treat conversions for BTC, ETH, SOL, and DOGE as quick estimates rather than long-lived quotes.</p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Use Pairs as a Shortcut</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Popular pairs like USD to EUR or EUR to USD are often enough for quick checks. Start there, then fine-tune the amount.</p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Compare Related Costs Too</h3>
        <p class="text-sm text-[var(--color-text-muted)]">If you are budgeting internationally, you may also want to compare loan costs, invoice totals, or unit conversions in the same session.</p>
      </div>
    </div>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="popular-conversions">
    <h2 id="popular-conversions" class="text-xl font-bold text-[var(--color-text)] mb-3">Popular Currency Conversions</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {[
        { slug: '100-usd-to-eur', label: '100 USD to EUR' },
        { slug: '100-eur-to-usd', label: '100 EUR to USD' },
        { slug: '100-usd-to-gbp', label: '100 USD to GBP' },
        { slug: '100-gbp-to-usd', label: '100 GBP to USD' },
        { slug: '100-usd-to-jpy', label: '100 USD to JPY' },
        { slug: '100-eur-to-gbp', label: '100 EUR to GBP' },
        { slug: '1-btc-to-usd', label: '1 BTC to USD' },
        { slug: '1-eth-to-usd', label: '1 ETH to USD' },
      ].map((link) => (
        <a href={`/convert/${link.slug}`}
          class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center">
          <span class="text-sm font-medium">{link.label}</span>
        </a>
      ))}
    </div>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="next-steps">
    <h2 id="next-steps" class="text-xl font-bold text-[var(--color-text)] mb-3">Related Tools for International Planning</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
      <a href="/invoice-generator" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Invoice Generator</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Create invoices after checking cross-border pricing or estimating totals in the right billing currency.</p>
      </a>
      <a href="/loan-calculator" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Loan Calculator</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Compare borrowing costs after translating amounts into the currency you actually budget in.</p>
      </a>
      <a href="/percentage-calculator" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Percentage Calculator</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Check spreads, fees, VAT, discounts, or markup percentages after converting the base amount.</p>
      </a>
      <a href="/unit-converter" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Unit Converter</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Useful when international shopping or supplier research also requires size, weight, or volume conversions.</p>
      </a>
    </div>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="currency-pages">
    <h2 id="currency-pages" class="text-xl font-bold text-[var(--color-text)] mb-3">Browse by Currency</h2>
    <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-6 gap-2">
      {[
        { code: 'usd', label: 'USD' },
        { code: 'eur', label: 'EUR' },
        { code: 'gbp', label: 'GBP' },
        { code: 'jpy', label: 'JPY' },
        { code: 'chf', label: 'CHF' },
        { code: 'cad', label: 'CAD' },
        { code: 'aud', label: 'AUD' },
        { code: 'cny', label: 'CNY' },
        { code: 'inr', label: 'INR' },
        { code: 'krw', label: 'KRW' },
        { code: 'btc', label: 'BTC' },
        { code: 'eth', label: 'ETH' },
      ].map((c) => (
        <a href={`/currency/${c.code}`}
          class="p-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center">
          <span class="text-sm font-medium">{c.label}</span>
        </a>
      ))}
    </div>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="currency-disclaimer">
    <div class="rounded-xl border px-4 py-3 text-sm" style="background: var(--color-warning-bg, var(--color-surface-alt)); border-color: var(--color-border); color: var(--color-text-muted);">
      <h2 id="currency-disclaimer" class="font-semibold text-[var(--color-text)] mb-1">Planning Tool, Not Financial Advice</h2>
      <p>
        Exchange rates change constantly, and provider fees can affect the final amount you pay or receive. Use this tool for fast comparison and planning, then confirm the final rate with your bank, broker, exchange, or payment provider.
      </p>
    </div>
  </section>
</ToolLayout>
