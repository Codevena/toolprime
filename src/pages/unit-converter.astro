---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { UnitConverter } from '@/components/tools/UnitConverter'
import { getToolById } from '@/data/tools'

const tool = getToolById('unit-converter')
if (!tool) throw new Error('Tool not found: unit-converter')
---

<ToolLayout tool={tool}>
  <UnitConverter client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Unit Converter</h2>
    <ol class="step-list" role="list">
      <li>Select a conversion category (Length, Weight, Temperature, etc.)</li>
      <li>Choose the source and target units from the dropdowns</li>
      <li>Enter a value in the input field</li>
      <li>See the converted result instantly</li>
      <li>View the conversion table for common values</li>
    </ol>
  </section>
</ToolLayout>
