---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import { colorPalettes, paletteCategoryLabels, type PaletteCategory } from '@/data/colorPalettes'
import { getPaletteIndexMeta } from '@/lib/seo'

const meta = getPaletteIndexMeta()
const categories = Object.keys(paletteCategoryLabels) as PaletteCategory[]
---

<BaseLayout {...meta}>
  <Breadcrumbs items={[
    { name: 'Color Palette Generator', url: 'https://toolprime.dev/color-palette-generator' },
    { name: 'All Palettes', url: meta.canonical },
  ]} />

  <h1 class="text-3xl font-bold mb-2">Curated Color Palettes</h1>
  <p class="text-[var(--color-text-muted)] mb-8">Browse 50 handpicked color palettes with HEX, RGB, HSL values, CSS variables, and Tailwind config snippets.</p>

  {categories.map(cat => {
    const catPalettes = colorPalettes.filter(p => p.category === cat)
    const label = paletteCategoryLabels[cat]
    return (
      <section class="mb-10" aria-labelledby={`cat-${cat}`}>
        <h2 id={`cat-${cat}`} class="text-xl font-bold text-[var(--color-text)] mb-4">{label}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {catPalettes.map(p => (
            <a href={`/palettes/${p.slug}`}
              class="rounded-xl border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-primary)] transition-colors bg-[var(--color-surface)]">
              <div class="flex h-16">
                {p.colors.map(c => (
                  <div class="flex-1" style={`background-color: ${c.hex}`} />
                ))}
              </div>
              <div class="p-3">
                <span class="text-sm font-semibold text-[var(--color-text)]">{p.name}</span>
                <span class="block text-xs text-[var(--color-text-muted)] mt-0.5">{p.colors.map(c => c.hex).join(' ')}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  })}
</BaseLayout>
