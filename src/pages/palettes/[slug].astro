---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import SchemaMarkup from '@/components/seo/SchemaMarkup.astro'
import FaqSection from '@/components/seo/FaqSection.astro'
import { colorPalettes, getRelatedPalettes } from '@/data/colorPalettes'
import { getPaletteMeta } from '@/lib/seo'
import { paletteFaqSchema } from '@/lib/schema'

export function getStaticPaths() {
  return colorPalettes.map((preset) => ({
    params: { slug: preset.slug },
    props: { preset },
  }))
}

interface Props {
  preset: typeof colorPalettes[number]
}

const { preset } = Astro.props
const meta = getPaletteMeta(preset.name, preset.slug, preset.description)
const related = getRelatedPalettes(preset.slug)

function hexToRgb(hex: string) {
  const c = hex.replace('#', '')
  const r = parseInt(c.slice(0, 2), 16)
  const g = parseInt(c.slice(2, 4), 16)
  const b = parseInt(c.slice(4, 6), 16)
  return { r, g, b }
}

function rgbToHsl(r: number, g: number, b: number) {
  const rn = r / 255, gn = g / 255, bn = b / 255
  const max = Math.max(rn, gn, bn), min = Math.min(rn, gn, bn)
  const l = (max + min) / 2
  if (max === min) return { h: 0, s: 0, l: Math.round(l * 100) }
  const d = max - min
  const s = l > 0.5 ? d / (2 - max - min) : d / (max + min)
  let h = 0
  if (max === rn) h = ((gn - bn) / d + (gn < bn ? 6 : 0)) / 6
  else if (max === gn) h = ((bn - rn) / d + 2) / 6
  else h = ((rn - gn) / d + 4) / 6
  return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) }
}

const cssVars = `:root {\n${preset.colors.map((c, i) => `  --${preset.slug}-${i + 1}: ${c.hex};`).join('\n')}\n}`

const tailwindConfig = `// tailwind.config.js
module.exports = {
  theme: {
    extend: {
      colors: {
        '${preset.slug}': {
${preset.colors.map((c, i) => `          '${(i + 1) * 100}': '${c.hex}',`).join('\n')}
        },
      },
    },
  },
}`
---

<BaseLayout {...meta}>
  <SchemaMarkup json={paletteFaqSchema(preset.faqs)} slot="head" />

  <Breadcrumbs items={[
    { name: 'Color Palette Generator', url: 'https://toolprime.dev/color-palette-generator' },
    { name: 'All Palettes', url: 'https://toolprime.dev/palettes' },
    { name: preset.name, url: meta.canonical },
  ]} />

  <h1 class="text-3xl font-bold mb-2">{preset.title}</h1>
  <p class="text-[var(--color-text-muted)] mb-6">{preset.description}</p>

  {/* Color Swatches */}
  <div class="flex rounded-xl overflow-hidden border border-[var(--color-border)] mb-6">
    {preset.colors.map(c => (
      <div class="flex-1 h-24 sm:h-32" style={`background-color: ${c.hex}`} />
    ))}
  </div>

  {/* Color Details */}
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 mb-8">
    {preset.colors.map(c => {
      const rgb = hexToRgb(c.hex)
      const hsl = rgbToHsl(rgb.r, rgb.g, rgb.b)
      return (
        <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden">
          <div class="h-12" style={`background-color: ${c.hex}`} />
          <div class="p-3">
            <p class="text-sm font-semibold text-[var(--color-text)] mb-1">{c.name}</p>
            <div class="text-xs font-mono text-[var(--color-text-muted)] space-y-0.5">
              <p>HEX: {c.hex}</p>
              <p>RGB: rgb({rgb.r}, {rgb.g}, {rgb.b})</p>
              <p>HSL: hsl({hsl.h}, {hsl.s}%, {hsl.l}%)</p>
            </div>
          </div>
        </div>
      )
    })}
  </div>

  {/* CSS Variables */}
  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 mb-6">
    <h2 class="text-lg font-semibold mb-4">CSS Variables</h2>
    <div class="flex items-start gap-3">
      <pre id="css-code" class="flex-1 bg-[var(--color-surface-alt)] p-3 rounded-lg text-sm font-mono overflow-x-auto"><code>{cssVars}</code></pre>
      <button type="button" id="copy-css" class="shrink-0 px-3 py-1.5 text-sm rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface-alt)] transition-colors">
        Copy
      </button>
    </div>
  </div>

  {/* Tailwind Config */}
  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 mb-8">
    <h2 class="text-lg font-semibold mb-4">Tailwind CSS Config</h2>
    <div class="flex items-start gap-3">
      <pre id="tw-code" class="flex-1 bg-[var(--color-surface-alt)] p-3 rounded-lg text-sm font-mono overflow-x-auto"><code>{tailwindConfig}</code></pre>
      <button type="button" id="copy-tw" class="shrink-0 px-3 py-1.5 text-sm rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface-alt)] transition-colors">
        Copy
      </button>
    </div>
  </div>

  <script>
    document.getElementById('copy-css')?.addEventListener('click', function() {
      const code = document.querySelector('#css-code code')?.textContent ?? ''
      navigator.clipboard.writeText(code)
      this.textContent = 'Copied!'
      setTimeout(() => { this.textContent = 'Copy' }, 2000)
    })
    document.getElementById('copy-tw')?.addEventListener('click', function() {
      const code = document.querySelector('#tw-code code')?.textContent ?? ''
      navigator.clipboard.writeText(code)
      this.textContent = 'Copied!'
      setTimeout(() => { this.textContent = 'Copy' }, 2000)
    })
  </script>

  {/* Use Cases */}
  {preset.useCases.length > 0 && (
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-3">Use Cases</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {preset.useCases.map(uc => (
          <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] px-4 py-3">
            <span class="text-sm text-[var(--color-text)]">{uc}</span>
          </div>
        ))}
      </div>
    </div>
  )}

  {/* Related Palettes */}
  {related.length > 0 && (
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-4">Related Palettes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {related.map(p => (
          <a href={`/palettes/${p.slug}`}
            class="rounded-lg border border-[var(--color-border)] overflow-hidden hover:border-[var(--color-primary)] transition-colors">
            <div class="flex h-16">
              {p.colors.map(c => (
                <div class="flex-1" style={`background-color: ${c.hex}`} />
              ))}
            </div>
            <div class="p-3">
              <span class="text-sm font-medium">{p.name}</span>
              <span class="block text-xs text-[var(--color-text-muted)]">{p.colors.map(c => c.hex).join(' ')}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <FaqSection faqs={preset.faqs} />
</BaseLayout>
