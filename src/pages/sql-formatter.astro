---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { SqlFormatter } from '@/components/tools/SqlFormatter'
import { getToolById } from '@/data/tools'

const tool = getToolById('sql-formatter')
if (!tool) throw new Error('Tool not found: sql-formatter')
---

<ToolLayout tool={tool}>
  <SqlFormatter client:load />

  <section slot="content" class="mt-8 prose prose-slate max-w-none dark:prose-invert">
    <h2>How to Use the SQL Formatter</h2>
    <p>
      Paste your SQL query into the input field. The formatter instantly beautifies it with proper indentation and line breaks. Choose your SQL dialect (Standard SQL, MySQL, PostgreSQL, T-SQL, or PL/SQL) for dialect-specific formatting.
    </p>
    <p>
      Adjust the indentation size (2 or 4 spaces) and toggle uppercase keywords to match your style preferences. Click <strong>Copy</strong> to copy the formatted SQL to your clipboard.
    </p>

    <h2>Privacy</h2>
    <p>
      All SQL formatting is performed locally in your browser. Your queries are never sent to any server or stored anywhere.
    </p>
  </section>
</ToolLayout>
