---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { SqlFormatter } from '@/components/tools/SqlFormatter'
import { getToolById } from '@/data/tools'

const tool = getToolById('sql-formatter')
if (!tool) throw new Error('Tool not found: sql-formatter')
---

<ToolLayout tool={tool}>
  <SqlFormatter client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the SQL Formatter</h2>
    <ol class="step-list" role="list">
      <li>Paste your SQL query into the input area</li>
      <li>Select your SQL dialect (Standard, MySQL, PostgreSQL, T-SQL, PL/SQL)</li>
      <li>Click <strong>Format</strong> to beautify with proper indentation</li>
      <li>Toggle uppercase keywords on or off</li>
      <li>Copy the formatted output</li>
    </ol>
  </section>
</ToolLayout>
