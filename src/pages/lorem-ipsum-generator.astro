---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { LoremIpsumGenerator } from '@/components/tools/LoremIpsumGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('lorem-ipsum-generator')
if (!tool) throw new Error('Tool not found: lorem-ipsum-generator')
---

<ToolLayout tool={tool}>
  <LoremIpsumGenerator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Lorem Ipsum Generator</h2>
    <ol class="step-list" role="list">
      <li>Choose the output type: paragraphs, sentences, or words</li>
      <li>Set the desired quantity using the input field</li>
      <li>Toggle "Start with Lorem Ipsum" if you want the classic opening</li>
      <li>Click <strong>Generate</strong> to create placeholder text</li>
      <li>Copy the result with one click</li>
    </ol>
  </section>
</ToolLayout>
