---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { LoremIpsumGenerator } from '@/components/tools/LoremIpsumGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('lorem-ipsum-generator')
if (!tool) throw new Error('Tool not found: lorem-ipsum-generator')
---

<ToolLayout tool={tool}>
  <LoremIpsumGenerator client:load />

  <section slot="content" class="mt-8 prose prose-slate max-w-none dark:prose-invert">
    <h2>How to Use the Lorem Ipsum Generator</h2>
    <p>
      Set the <strong>Count</strong> field to the number of units you want to generate — between 1 and 50. Then choose a <strong>Type</strong>: Paragraphs generates full blocks of text, Sentences generates individual sentences, and Words generates a sequence of individual words. The text appears immediately in the output area.
    </p>
    <p>
      Click <strong>Shuffle</strong> to generate a different random arrangement of the same type and count. This is useful when you want variety in your placeholder text so repeated blocks do not all look identical in a design mockup. Use the <strong>Copy</strong> button to copy all the generated text to your clipboard with one click.
    </p>
    <p>
      The generated paragraphs each contain 4–7 sentences drawn from the classic Lorem Ipsum corpus. This produces realistic-looking blocks of text with natural paragraph length variation, which is more useful for layout testing than perfectly uniform blocks.
    </p>

    <h2>Privacy</h2>
    <p>
      All Lorem Ipsum text is generated entirely in your browser from a built-in word list. No network requests are made and no data is sent anywhere.
    </p>
  </section>
</ToolLayout>
