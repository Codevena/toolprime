---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { DateCalculator } from '@/components/tools/DateCalculator'
import { getToolById } from '@/data/tools'

const tool = getToolById('date-calculator')
if (!tool) throw new Error('Tool not found: date-calculator')
---

<ToolLayout tool={tool}>
  <DateCalculator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Date Calculator</h2>
    <ol class="step-list" role="list">
      <li>Choose a mode: <strong>Days Between</strong>, <strong>Add Days</strong>, or <strong>Subtract Days</strong></li>
      <li>Enter your dates or number of days</li>
      <li>View the result instantly — days, weeks, and the resulting date</li>
    </ol>
  </section>
</ToolLayout>
