---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { GradientIcon } from '@/components/ui/GradientIcon'
import SchemaMarkup from '@/components/seo/SchemaMarkup.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import { getToolById } from '@/data/tools'
import { audienceHubs } from '@/data/audienceHubs'
import { getHubMeta } from '@/lib/seo'
import { breadcrumbSchema } from '@/lib/schema'

const hub = audienceHubs.find((h) => h.audience === 'developer')!
const meta = getHubMeta(hub.title, hub.description, '/developer')
---

<BaseLayout {...meta}>
  <SchemaMarkup json={breadcrumbSchema([
    { name: 'Home', url: 'https://toolprime.dev/' },
    { name: 'Developer Tools', url: 'https://toolprime.dev/developer' },
  ])} />

  <Breadcrumbs items={[{ name: 'Developer Tools', url: 'https://toolprime.dev/developer' }]} />

  {/* Hero */}
  <section class="text-center pt-8 pb-12">
    <h1 class="text-4xl sm:text-5xl font-extrabold mb-3 tracking-tight" style="letter-spacing: -0.03em;">
      <span class="bg-clip-text text-transparent" style={`background-image: ${hub.gradient};`}>
        {hub.heading}
      </span>
    </h1>
    <p class="text-[var(--color-text-muted)] text-base mb-8 max-w-lg mx-auto">
      {hub.subheading}
    </p>
  </section>

  <section class="mb-12">
    <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
        <div class="lg:col-span-2">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">Start Here if You Need Fast Developer Utilities</h2>
          <p class="text-sm leading-relaxed text-[var(--color-text-muted)] mb-4">
            This hub is built for the kinds of tasks that interrupt development flow: inspecting API payloads, formatting SQL, testing regex patterns, decoding strings, generating hashes, and converting data between formats. The fastest path is usually to start with the tool that matches the data in front of you, then move to a related workflow tool instead of starting over elsewhere.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <a href="/json-formatter" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Debug JSON</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Format, validate, and inspect unreadable payloads before you compare or transform them.</p>
            </a>
            <a href="/regex-tester" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Test Patterns</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Prototype regular expressions and validate extraction logic on real text.</p>
            </a>
            <a href="/base64-encode-decode" class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 hover:border-[var(--color-primary)] transition-colors">
              <h3 class="text-sm font-semibold text-[var(--color-text)] mb-1">Decode Data</h3>
              <p class="text-sm text-[var(--color-text-muted)]">Handle Base64 strings, tokens, and encoded blobs without leaving the browser.</p>
            </a>
          </div>
        </div>
        <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-5">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Most Useful First</h2>
          <div class="space-y-3">
            <a href="/json-formatter" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">JSON Formatter</div>
              <div class="text-sm text-[var(--color-text-muted)]">Best starting point for API and config debugging.</div>
            </a>
            <a href="/sql-formatter" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">SQL Formatter</div>
              <div class="text-sm text-[var(--color-text-muted)]">Turn unreadable queries into something you can review.</div>
            </a>
            <a href="/timestamp-converter" class="block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 hover:border-[var(--color-primary)] transition-colors">
              <div class="font-semibold text-[var(--color-text)]">Timestamp Converter</div>
              <div class="text-sm text-[var(--color-text-muted)]">Quickly translate epoch values while debugging logs and APIs.</div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-bold text-[var(--color-text)] mb-4">Common Developer Workflows</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">API Response Debugging</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Start with unreadable JSON, inspect structure, compare changes, and decode embedded values.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/json-formatter" class="text-[var(--color-primary)] underline hover:no-underline">JSON Formatter</a> → <a href="/diff-checker" class="text-[var(--color-primary)] underline hover:no-underline">Diff Checker</a> → <a href="/base64-encode-decode" class="text-[var(--color-primary)] underline hover:no-underline">Base64</a></p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">Validation and Parsing</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Test patterns, verify dates and strings, then clean up input before moving it through a system.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/regex-tester" class="text-[var(--color-primary)] underline hover:no-underline">Regex Tester</a> → <a href="/timestamp-converter" class="text-[var(--color-primary)] underline hover:no-underline">Timestamp Converter</a> → <a href="/url-encode-decode" class="text-[var(--color-primary)] underline hover:no-underline">URL Encode/Decode</a></p>
      </div>
      <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
        <h3 class="text-sm font-semibold text-[var(--color-text)] mb-2">Config and Infra Setup</h3>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Generate metadata and crawler rules when shipping a site, app, or integration surface.</p>
        <p class="text-sm text-[var(--color-text)]">Use: <a href="/meta-tag-generator" class="text-[var(--color-primary)] underline hover:no-underline">Meta Tags</a> → <a href="/robots-txt-generator" class="text-[var(--color-primary)] underline hover:no-underline">robots.txt</a> → <a href="/cron-expression-generator" class="text-[var(--color-primary)] underline hover:no-underline">Cron</a></p>
      </div>
    </div>
  </section>

  {/* Subcategory Sections */}
  {hub.subcategories.map((sub) => {
    const subTools = sub.toolIds.map((id) => getToolById(id)).filter((t) => t !== undefined)
    if (subTools.length === 0) return null
    return (
      <section class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <h2 class="text-xs font-semibold uppercase tracking-wider whitespace-nowrap text-[var(--color-text-muted)]">
            {sub.name}
          </h2>
          <div class="flex-1 h-px bg-[var(--color-border)]" style="opacity:0.4;" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {subTools.map((tool) => (
            <a
              href={tool.path}
              class="group flex items-start gap-3 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] hover:shadow-lg hover:-translate-y-px transition-all"
            >
              <GradientIcon icon={tool.icon} category={tool.category} size={36} />
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-[var(--color-text)] mb-0.5">{tool.name}</h3>
                <p class="text-xs text-[var(--color-text-muted)] line-clamp-2">{tool.description}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )
  })}

  {/* Browse Other Categories */}
  <section class="border-t border-[var(--color-border-subtle)] pt-8 mt-8">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-4">Browse Other Categories</h2>
    <div class="flex flex-wrap gap-3">
      <a href="/everyday" class="px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)] transition-all">
        Everyday Tools
      </a>
      <a href="/design" class="px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-primary)] transition-all">
        Design Tools
      </a>
    </div>
  </section>
</BaseLayout>
