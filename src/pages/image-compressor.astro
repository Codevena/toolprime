---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { ImageCompressor } from '@/components/tools/ImageCompressor'
import { getToolById } from '@/data/tools'

const tool = getToolById('image-compressor')
if (!tool) throw new Error('Tool not found: image-compressor')
---

<ToolLayout tool={tool}>
  <ImageCompressor client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Image Compressor</h2>
    <ol class="step-list" role="list">
      <li>Click the upload area or drag and drop your image</li>
      <li>Adjust the quality slider to set compression level</li>
      <li>Preview the compressed result and compare file sizes</li>
      <li>Click <strong>Download</strong> to save the compressed image</li>
    </ol>
  </section>
</ToolLayout>
