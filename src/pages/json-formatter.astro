---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { JsonFormatter } from '@/components/tools/JsonFormatter'
import { getToolById } from '@/data/tools'

const tool = getToolById('json-formatter')
if (!tool) throw new Error('Tool not found: json-formatter')
---

<ToolLayout tool={tool}>
  <JsonFormatter client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the JSON Formatter</h2>
    <ol class="step-list" role="list">
      <li><strong>Paste</strong> your JSON data into the input field</li>
      <li>Click <strong>Format</strong> to beautify with proper indentation</li>
      <li>Click <strong>Minify</strong> to compress to a single line, or <strong>Validate</strong> to check syntax</li>
      <li>Choose between <strong>2-space</strong> or <strong>4-space</strong> indentation</li>
      <li>Errors display with <strong>line numbers</strong> and details</li>
    </ol>
  </section>
</ToolLayout>
