---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { Base64EncodeDecode } from '@/components/tools/Base64EncodeDecode'
import { getToolById } from '@/data/tools'

const tool = getToolById('base64-encode-decode')
if (!tool) throw new Error('Tool not found: base64-encode-decode')
---

<ToolLayout tool={tool}>
  <Base64EncodeDecode client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Base64 Encoder & Decoder</h2>
    <ol class="step-list" role="list">
      <li>Paste your text or Base64 string into the input field</li>
      <li>Click <strong>Encode</strong> to convert text to Base64</li>
      <li>Click <strong>Decode</strong> to convert Base64 back to readable text</li>
      <li>Copy the result with the copy button</li>
    </ol>
  </section>
</ToolLayout>
