---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { QrCodeGenerator } from '@/components/tools/QrCodeGenerator'
import { getToolById } from '@/data/tools'

const tool = getToolById('qr-code-generator')
if (!tool) throw new Error('Tool not found: qr-code-generator')
---

<ToolLayout tool={tool}>
  <QrCodeGenerator client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the QR Code Generator</h2>
    <ol class="step-list" role="list">
      <li>Enter your <strong>URL</strong>, <strong>text</strong>, <strong>WiFi credentials</strong>, or other data</li>
      <li>Choose the <strong>error correction level</strong> (L, M, Q, H)</li>
      <li>Preview the <strong>QR code</strong> in real time</li>
      <li>Download as <strong>PNG</strong> or <strong>SVG</strong> format</li>
      <li>Test by <strong>scanning with your phone</strong> before printing</li>
    </ol>
  </section>
</ToolLayout>
