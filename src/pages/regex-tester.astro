---
import ToolLayout from '@/layouts/ToolLayout.astro'
import { RegexTester } from '@/components/tools/RegexTester'
import { getToolById } from '@/data/tools'

const tool = getToolById('regex-tester')
if (!tool) throw new Error('Tool not found: regex-tester')
---

<ToolLayout tool={tool}>
  <RegexTester client:load />

  <section slot="content" class="mt-8" aria-labelledby="how-to-use">
    <h2 id="how-to-use" class="text-xl font-bold text-[var(--color-text)] mb-3">How to Use the Regex Tester</h2>
    <ol class="step-list" role="list">
      <li>Enter your regex pattern in the pattern field</li>
      <li>Toggle flags: global (g), case-insensitive (i), multiline (m)</li>
      <li>Paste your test string in the text area</li>
      <li>See matches highlighted in real time with capture groups</li>
      <li>View match details including index positions</li>
    </ol>
  </section>

  <section slot="content" class="mt-8" aria-labelledby="related-content">
    <h2 id="related-content" class="text-xl font-bold text-[var(--color-text)] mb-3">Common Regex Patterns</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
      {[
        { slug: 'email-validation', name: 'Email' },
        { slug: 'url-validation', name: 'URL' },
        { slug: 'phone-number-us', name: 'Phone (US)' },
        { slug: 'ipv4-address', name: 'IPv4 Address' },
        { slug: 'date-yyyy-mm-dd', name: 'Date (YYYY-MM-DD)' },
        { slug: 'uuid', name: 'UUID' },
      ].map((p) => (
        <a href={`/regex/${p.slug}`}
          class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors">
          <span class="text-sm font-medium">Regex for {p.name}</span>
        </a>
      ))}
    </div>
  </section>
</ToolLayout>
