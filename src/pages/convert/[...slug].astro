---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import FaqSection from '@/components/seo/FaqSection.astro'
import SchemaMarkup from '@/components/seo/SchemaMarkup.astro'
import { GradientIcon } from '@/components/ui/GradientIcon'
import { formatConversions, type FormatConversion } from '@/data/formatConversions'
import { getToolById, getRelatedTools } from '@/data/tools'
import { getFormatConversionMeta, getCurrencyConversionMeta, getNumberBaseMeta, getHexToDecimalMeta, getAsciiMeta } from '@/lib/seo'
import { formatConversionHowToSchema, faqPageSchema } from '@/lib/schema'
import CurrencyConversionPage from '@/components/pseo/CurrencyConversionPage.astro'
import NumberBaseConversionPage from '@/components/pseo/NumberBaseConversionPage.astro'
import AdSlot from '@/components/ads/AdSlot.astro'
import { NumberBaseConverter } from '@/components/tools/NumberBaseConverter'
import AsciiPage from '@/components/pseo/AsciiPage.astro'
import {
  currencyEntries,
  fetchRates,
  getRateDate,
  convertCurrency,
  getCurrencyByCode,
  type CurrencyEntry,
  type RateMap,
} from '@/data/currencyData'
import {
  numberBaseEntries,
  hexToDecimalEntries,
  asciiEntries,
  type NumberBaseEntry,
  type HexToDecimalEntry,
  type AsciiEntry,
} from '@/data/numberBaseData'
import type { MetaTags } from '@/lib/seo'

type PageProps =
  | { type: 'format'; conv: FormatConversion; currency: null; rates: null; numberBase: null; hexToDec: null; ascii: null }
  | { type: 'currency'; conv: null; currency: CurrencyEntry; rates: RateMap; numberBase: null; hexToDec: null; ascii: null }
  | { type: 'numberBase'; conv: null; currency: null; rates: null; numberBase: NumberBaseEntry; hexToDec: null; ascii: null }
  | { type: 'hexToDec'; conv: null; currency: null; rates: null; numberBase: null; hexToDec: HexToDecimalEntry; ascii: null }
  | { type: 'ascii'; conv: null; currency: null; rates: null; numberBase: null; hexToDec: null; ascii: AsciiEntry }

export async function getStaticPaths() {
  const formatPaths = formatConversions.map((conv) => ({
    params: { slug: conv.slug },
    props: { type: 'format' as const, conv, currency: null, rates: null, numberBase: null, hexToDec: null, ascii: null },
  }))

  const rates = await fetchRates()

  const currencyPaths = currencyEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { type: 'currency' as const, conv: null, currency: entry, rates, numberBase: null, hexToDec: null, ascii: null },
  }))

  const numberBasePaths = numberBaseEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { type: 'numberBase' as const, conv: null, currency: null, rates: null, numberBase: entry, hexToDec: null, ascii: null },
  }))

  const hexToDecPaths = hexToDecimalEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { type: 'hexToDec' as const, conv: null, currency: null, rates: null, numberBase: null, hexToDec: entry, ascii: null },
  }))

  const asciiPaths = asciiEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { type: 'ascii' as const, conv: null, currency: null, rates: null, numberBase: null, hexToDec: null, ascii: entry },
  }))

  return [...formatPaths, ...currencyPaths, ...numberBasePaths, ...hexToDecPaths, ...asciiPaths]
}

const props = Astro.props as PageProps

let meta: MetaTags
if (props.type === 'format') {
  meta = getFormatConversionMeta(props.conv)
} else if (props.type === 'currency') {
  const { amount, fromCode, toCode } = props.currency
  const from = getCurrencyByCode(fromCode)!
  const to = getCurrencyByCode(toCode)!
  const result = convertCurrency(amount, fromCode, toCode, props.rates)
  meta = getCurrencyConversionMeta(amount, fromCode, from.name, toCode, to.name, result)
} else if (props.type === 'numberBase') {
  meta = getNumberBaseMeta(props.numberBase.value, 'decimal', props.numberBase.toBase, props.numberBase.result)
} else if (props.type === 'hexToDec') {
  meta = getHexToDecimalMeta(props.hexToDec.hex, props.hexToDec.decimal)
} else {
  meta = getAsciiMeta(props.ascii.code, props.ascii.char)
}
---

<BaseLayout {...meta}>
  {props.type === 'format' && (
    <>
      <SchemaMarkup json={formatConversionHowToSchema(props.conv.title, props.conv.steps)} slot="head" />

      <Breadcrumbs items={[
        { name: 'Convert', url: 'https://toolprime.dev/convert' },
        { name: props.conv.title, url: meta.canonical },
      ]} />

      <h1 class="text-3xl font-bold mb-2">{props.conv.title}</h1>
      <p class="text-[var(--color-text-muted)] mb-6">{props.conv.intro}</p>

      {(() => {
        const tool = getToolById(props.conv.toolId)
        const relatedTools = tool ? getRelatedTools(tool.id) : []
        const relatedConversions = props.conv.relatedConversions
          .map((slug: string) => formatConversions.find((c) => c.slug === slug))
          .filter((c: FormatConversion | undefined): c is FormatConversion => c !== undefined)
        return (
          <>
            {tool && (
              <a href={tool.path} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold text-white transition-colors mb-8" style="background: linear-gradient(135deg, #818cf8, #6366f1);">
                <GradientIcon icon={tool.icon} category={tool.category} size={20} />
                Open {tool.name} &rarr;
              </a>
            )}

            <div class="prose prose-slate max-w-none dark:prose-invert">
              <h2>How to {props.conv.title}</h2>
              <ol>
                {props.conv.steps.map((step: string) => <li>{step}</li>)}
              </ol>

              <h2>Common Use Cases</h2>
              <ul>
                {props.conv.useCases.map((uc: string) => <li>{uc}</li>)}
              </ul>
            </div>

            <FaqSection faqs={props.conv.faqs} />

            {relatedConversions.length > 0 && (
              <div class="mt-8">
                <h2 class="text-xl font-semibold mb-4">Related Conversions</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  {relatedConversions.map((rc: FormatConversion) => (
                    <a href={`/convert/${rc.slug}`}
                      class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors">
                      <span class="text-sm font-medium">{rc.title}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}

            {tool && (
              <div class="mt-8">
                <h2 class="text-lg font-bold mb-4">Related Tools</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  <a href={tool.path} class="rounded-lg border border-[var(--color-border)] p-3 hover:border-[var(--color-primary)] transition-colors flex items-center gap-2">
                    <GradientIcon icon={tool.icon} category={tool.category} size={20} />
                    <span class="text-sm font-medium text-[var(--color-text)]">{tool.name}</span>
                  </a>
                  {relatedTools.map((rt) => (
                    <a href={rt.path} class="rounded-lg border border-[var(--color-border)] p-3 hover:border-[var(--color-primary)] transition-colors flex items-center gap-2">
                      <GradientIcon icon={rt.icon} category={rt.category} size={20} />
                      <span class="text-sm font-medium text-[var(--color-text)]">{rt.name}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </>
        )
      })()}
    </>
  )}

  {props.type === 'currency' && (
    <>
      <CurrencyConversionPage
        amount={props.currency.amount}
        fromCode={props.currency.fromCode}
        toCode={props.currency.toCode}
        rates={props.rates}
      />
      <p class="mt-4 text-xs text-[var(--color-text-muted)]">
        Rates from the European Central Bank via Frankfurter API. Updated daily.
        {getRateDate() !== 'fallback' && getRateDate() !== 'unknown' && <> As of <strong>{getRateDate()}</strong>.</>}
      </p>
    </>
  )}

  {props.type === 'numberBase' && (
    <NumberBaseConversionPage entry={props.numberBase} />
  )}

  {props.type === 'hexToDec' && (() => {
    const entry = props.hexToDec
    const faqJson = faqPageSchema([
      { question: `What is ${entry.hex} hex in decimal?`, answer: `Hexadecimal ${entry.hex} in decimal is ${entry.decimal}.` },
      { question: `How do you convert hex to decimal?`, answer: `Multiply each hex digit by its positional power of 16, then sum the results. Our converter handles this instantly.` },
    ])
    return (
      <>
        <SchemaMarkup json={faqJson} slot="head" />
        <Breadcrumbs items={[
          { name: 'Number Base Converter', url: 'https://toolprime.dev/number-base-converter' },
          { name: `${entry.hex} Hex to Decimal`, url: `https://toolprime.dev/convert/${entry.slug}` },
        ]} />
        <h1 class="text-3xl font-bold mb-2">0x{entry.hex} in Decimal = {entry.decimal}</h1>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 mb-8">
          <p class="text-lg text-[var(--color-text-muted)] mb-1">Decimal Representation</p>
          <p class="text-4xl font-bold font-mono text-[var(--color-primary-text)]">{entry.decimal}</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-2">0x{entry.hex} = {entry.decimal} (decimal)</p>
        </div>
        <AdSlot position="top" />
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 sm:p-6 mb-8">
          <h2 class="text-lg font-semibold mb-4">Try the Number Base Converter</h2>
          <NumberBaseConverter client:load defaultValue={entry.hex} defaultBase="hexadecimal" />
        </div>
        <AdSlot position="bottom" />
      </>
    )
  })()}

  {props.type === 'ascii' && (
    <AsciiPage entry={props.ascii} />
  )}
</BaseLayout>
