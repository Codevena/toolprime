---
import { faqPageSchema } from '@/lib/schema'
import SchemaMarkup from './SchemaMarkup.astro'
import type { Faq } from '@/data/faqs'

interface Props {
  faqs: Faq[]
}

const { faqs } = Astro.props
---

{faqs.length > 0 && (
  <section class="mt-12">
    <SchemaMarkup json={faqPageSchema(faqs)} />
    <h2 class="text-xl font-semibold mb-4">Frequently Asked Questions</h2>
    <div class="space-y-2">
      {faqs.map((faq) => (
        <details class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)]">
          <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-[var(--color-text)] flex items-center justify-between">
            {faq.question}
            <span class="text-[var(--color-text-muted)] group-open:rotate-180 transition-transform">▾</span>
          </summary>
          <div class="px-4 pb-3 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.answer}</div>
        </details>
      ))}
    </div>
  </section>
)}
