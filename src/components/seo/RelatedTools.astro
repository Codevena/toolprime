---
import { getRelatedTools } from '@/data/tools'

interface Props {
  toolId: string
}

const { toolId } = Astro.props
const related = getRelatedTools(toolId)
---

{related.length > 0 && (
  <section class="mt-12">
    <h2 class="text-xl font-semibold mb-4">Related Tools</h2>
    <div class="flex flex-wrap gap-2">
      {related.map((t) => (
        <a
          href={t.path}
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] text-sm text-[var(--color-text)] hover:border-[var(--color-primary)] transition-colors"
        >
          {t.name}
        </a>
      ))}
    </div>
  </section>
)}
