---
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import AdSlot from '@/components/ads/AdSlot.astro'
import { CurrencyConverter } from '@/components/tools/CurrencyConverter'
import { convertCurrency, currencies, type Currency, type RateMap } from '@/data/currencyData'

interface Props {
  currency: Currency
  rates: RateMap
}

const { currency, rates } = Astro.props
const code = currency.code

// Top 20 currencies to show rates for
const topCodes = ['USD', 'EUR', 'GBP', 'JPY', 'CHF', 'CAD', 'AUD', 'CNY', 'INR', 'KRW', 'NZD', 'SGD', 'HKD', 'SEK', 'NOK', 'BRL', 'MXN', 'ZAR', 'THB', 'AED']
const rateCurrencies = topCodes
  .filter((c) => c !== code)
  .map((c) => currencies.find((cur) => cur.code === c))
  .filter((c): c is Currency => c !== undefined)
  .slice(0, 20)

function fmt(v: number): string {
  if (v === 0) return '0'
  if (Math.abs(v) < 0.01) return v.toPrecision(4)
  if (Math.abs(v) >= 1_000_000) return v.toLocaleString('en-US', { maximumFractionDigits: 0 })
  return v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
}
---

<Breadcrumbs items={[
  { name: 'Currency Converter', url: 'https://toolprime.dev/currency-converter' },
  { name: `${currency.name} (${code})`, url: `https://toolprime.dev/currency/${code.toLowerCase()}` },
]} />

<h1 class="text-3xl font-bold mb-2">{currency.flag} {currency.name} ({code})</h1>
<p class="text-[var(--color-text-muted)] mb-6">
  Current {currency.name} exchange rates against {rateCurrencies.length} major currencies.
</p>

<AdSlot position="top" />

{/* Rate table */}
<div class="mb-8">
  <h2 class="text-xl font-semibold mb-4">1 {code} Exchange Rates</h2>
  <div class="rounded-xl border border-[var(--color-border)] overflow-hidden">
    <table class="w-full text-sm">
      <caption class="sr-only">{code} exchange rates</caption>
      <thead>
        <tr class="border-b border-[var(--color-border)] bg-[var(--color-surface-alt)]">
          <th scope="col" class="px-4 py-2.5 text-left text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">Currency</th>
          <th scope="col" class="px-4 py-2.5 text-right text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">1 {code} =</th>
        </tr>
      </thead>
      <tbody>
        {rateCurrencies.map((c) => (
          <tr class="border-b border-[var(--color-border)] last:border-b-0">
            <td class="px-4 py-2.5 text-sm text-[var(--color-text)]">
              <a href={`/currency/${c.code.toLowerCase()}`} class="hover:text-[var(--color-primary)] transition-colors">
                {c.flag} {c.name} ({c.code})
              </a>
            </td>
            <td class="px-4 py-2.5 text-sm text-right text-[var(--color-text-muted)]">
              <a href={`/convert/100-${code.toLowerCase()}-to-${c.code.toLowerCase()}`} class="hover:text-[var(--color-primary)] transition-colors">
                {fmt(convertCurrency(1, code, c.code, rates))}
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

{/* Interactive converter */}
<div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 sm:p-6 mb-8">
  <h2 class="text-lg font-semibold mb-4">Convert {code}</h2>
  <CurrencyConverter
    client:load
    defaultFrom={code}
    defaultTo={code === 'USD' ? 'EUR' : 'USD'}
    defaultAmount={100}
  />
</div>

{/* Conversion page links */}
<div class="mb-8">
  <h2 class="text-xl font-semibold mb-4">Popular {code} Conversions</h2>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
    {rateCurrencies.slice(0, 12).map((c) => (
      <a href={`/convert/100-${code.toLowerCase()}-to-${c.code.toLowerCase()}`}
        class="p-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface-alt)] hover:border-[var(--color-primary)] transition-colors text-center">
        <span class="text-sm font-medium">100 {code} to {c.code}</span>
      </a>
    ))}
  </div>
</div>

<AdSlot position="bottom" />
