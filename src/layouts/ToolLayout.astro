---
import BaseLayout from './BaseLayout.astro'
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro'
import RelatedTools from '@/components/seo/RelatedTools.astro'
import FaqSection from '@/components/seo/FaqSection.astro'
import AdSlot from '@/components/ads/AdSlot.astro'
import SchemaMarkup from '@/components/seo/SchemaMarkup.astro'
import { GradientIcon } from '@/components/ui/GradientIcon'
import { webApplicationSchema } from '@/lib/schema'
import { getToolMeta } from '@/lib/seo'
import { categoryLabels, type Tool } from '@/data/tools'
import { faqs as allFaqs } from '@/data/faqs'

interface Props {
  tool: Tool
}

const { tool } = Astro.props
const meta = getToolMeta(tool)
const toolFaqs = allFaqs[tool.id] ?? []
const categoryLabel = categoryLabels[tool.category]
---

<BaseLayout {...meta}>
  <SchemaMarkup json={webApplicationSchema(tool)} slot="head" />

  <Breadcrumbs items={[
    { name: categoryLabel, url: `https://toolprime.dev/#${tool.category}` },
    { name: tool.name, url: meta.canonical },
  ]} />

  <div class="flex items-center gap-3 mb-6">
    <GradientIcon icon={tool.icon} category={tool.category} size={40} />
    <div>
      <h1 class="text-2xl font-extrabold" style="letter-spacing: -0.02em;">{tool.name}</h1>
      <p class="text-sm text-[var(--color-text-muted)]">{tool.longDescription}</p>
    </div>
  </div>

  <AdSlot position="top" />

  <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4 sm:p-6">
    <slot />
  </div>

  <slot name="content" />

  {tool.content && (
    <section aria-label="About this tool" class="mt-8 space-y-8">
      {/* What Is Section — kept as prose paragraphs */}
      <div>
        <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">{tool.content.whatIs.heading}</h2>
        <div class="space-y-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
          {tool.content.whatIs.body.split('\n\n').map((p: string) => <p>{p}</p>)}
        </div>
      </div>

      {/* Use Cases — 2-column grid cards */}
      <div>
        <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">{tool.content.useCases.heading}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {tool.content.useCases.items.map((item: { title: string; description: string }) => (
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
              <h3 class="text-sm font-bold text-[var(--color-text)] mb-1">{item.title}</h3>
              <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Tips — 2-column grid cards */}
      <div>
        <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">{tool.content.tips.heading}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {tool.content.tips.items.map((item: { title: string; description: string }) => (
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-alt)] p-4">
              <h3 class="text-sm font-bold text-[var(--color-text)] mb-1">{item.title}</h3>
              <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Comparison Table (optional) — custom table style */}
      {tool.content.comparison && (
        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">{tool.content.comparison.heading}</h2>
          <div class="overflow-x-auto rounded-xl border border-[var(--color-border)]">
            <table class="w-full text-sm">
              <caption class="sr-only">{tool.content.comparison.heading}</caption>
              <thead>
                <tr class="border-b border-[var(--color-border)] bg-[var(--color-surface-alt)]">
                  {tool.content.comparison.headers.map((h: string) => (
                    <th scope="col" class="px-4 py-2.5 text-left text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {tool.content.comparison.rows.map((row: string[]) => (
                  <tr class="border-b border-[var(--color-border)] last:border-0">
                    {row.map((cell: string, i: number) =>
                      i === 0
                        ? <th scope="row" class="px-4 py-2.5 text-sm font-medium text-[var(--color-text)]">{cell}</th>
                        : <td class="px-4 py-2.5 text-sm text-[var(--color-text-muted)]">{cell}</td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </section>
  )}

  {/* Privacy Banner */}
  <aside role="note" aria-label="Privacy notice" class="mt-8 flex items-center gap-2.5 rounded-xl px-4 py-3 text-sm" style="background: var(--color-success-bg); border: 1px solid var(--color-success); color: var(--color-success-text);">
    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    All processing happens locally in your browser. Your data never leaves your device.
  </aside>

  <FaqSection faqs={toolFaqs} />
  <AdSlot position="bottom" />
  <RelatedTools toolId={tool.id} />
</BaseLayout>
